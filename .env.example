# Email Configuration (Required)
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password-here

MARIADB_ROOT_PASSWORD=root_password_here
MARIADB_PASSWORD=sql_password_here

# Admin API Key for sensitive operations (Required)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=your-secure-admin-key-here

# Development Account (optional - only used when DEBUG=True)
DEV_EMAIL=dev@cardsapp.local
DEV_USERNAME=dev
DEV_PASSWORD=

# Django Settings (recommended for production)
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT Secret Key (Required for API authentication)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here
